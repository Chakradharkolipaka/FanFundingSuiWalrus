# ─── FanFundingSui — Environment Variables ───
# Copy this file to .env.local and fill in your values.

# ─── Sui (client-visible) ───
# The Package ID from `sui client publish` output.
NEXT_PUBLIC_PACKAGE_ID=

# The shared Collection object ID from calling `init_collection`.
NEXT_PUBLIC_COLLECTION_ID=

# Sui fullnode RPC URL (testnet — already filled in)
NEXT_PUBLIC_SUI_NODE_URL=https://fullnode.testnet.sui.io:443

# ─── Storage (Walrus-first) ───
# Storage provider selection: walrus | pinata
STORAGE_PROVIDER=walrus

# Walrus write API (must be full upload endpoint, not just host root)
# Example: https://publisher.walrus-testnet.dev/v1/store
WALRUS_PUBLISHER_URL=

# Walrus read gateway base (used as <base>/<blobId>)
# Example: https://aggregator.walrus-testnet.dev/v1
WALRUS_GATEWAY_BASE_URL=

# Optional Walrus auth token
WALRUS_API_KEY=

# Pinata fallback (server-side only)
PINATA_JWT=
STORAGE_WALRUS_FALLBACK_TO_PINATA=true

# Optional upload API hardening
STORAGE_REQUIRE_AUTH=false
STORAGE_AUTH_TOKEN=
STORAGE_MAX_UPLOAD_MB=10
STORAGE_RATE_LIMIT_MAX=20
STORAGE_RATE_LIMIT_WINDOW_MS=60000
