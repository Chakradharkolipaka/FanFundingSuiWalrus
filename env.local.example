# ─── FanFundingSui — Environment Variables ───
# Fill in values after deploying the Sui Move contract.

# ─── Sui (client-visible) ───
# The Package ID from `sui client publish` output
NEXT_PUBLIC_PACKAGE_ID=

# The Collection shared object ID from `init_collection` call
NEXT_PUBLIC_COLLECTION_ID=

# Sui fullnode RPC URL (testnet)
NEXT_PUBLIC_SUI_NODE_URL=https://fullnode.testnet.sui.io:443

# zkLogin (Google)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# zkLogin prover provider
# - auto: prefer Enoki if configured, else use ZKLOGIN_PROVER_URL
# - enoki: always use Enoki
# - docker: always use ZKLOGIN_PROVER_URL
ZKLOGIN_PROVER_PROVIDER=auto

# Enoki (recommended if you want to avoid managing zkLogin.zkey yourself)
# NOTE: Fill these only if you are using Enoki.
# Versioned base URL (from https://docs.enoki.mystenlabs.com/http-api):
#   https://api.enoki.mystenlabs.com/v1
ENOKI_API_BASE_URL=https://api.enoki.mystenlabs.com/v1
ENOKI_API_KEY=

# zkLogin prover endpoint (Mysten hosted or your own)
# IMPORTANT:
# The default Mysten-hosted prover URL is NOT reachable from some environments (e.g. Vercel in certain regions)
# due to DNS/egress restrictions. If Google zkLogin fails with ENOTFOUND/502 from /api/zklogin/proof,
# you must set this to a prover URL that your runtime can reach (typically your own VPS domain).
#
# Example (self-hosted):
# ZKLOGIN_PROVER_URL=https://prover.your-domain.com/v1
ZKLOGIN_PROVER_URL=

# ─── Pinata / IPFS ───
# Server-side JWT (used by /api/pinata/upload — never exposed to browser)
PINATA_JWT=your_pinata_jwt_here

# Client-side JWT (only if uploading directly from browser via src/lib/ipfs.ts)
NEXT_PUBLIC_PINATA_JWT=
