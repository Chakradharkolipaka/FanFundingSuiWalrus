# ─── FanFundingSui — Environment Variables ───
# Fill in values after deploying the Sui Move contract.

# ─── Sui (client-visible) ───
# The Package ID from `sui client publish` output
NEXT_PUBLIC_PACKAGE_ID=

# The Collection shared object ID from `init_collection` call
NEXT_PUBLIC_COLLECTION_ID=

# Sui fullnode RPC URL (testnet)
NEXT_PUBLIC_SUI_NODE_URL=https://fullnode.testnet.sui.io:443

# zkLogin (Google)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# zkLogin prover provider
# - auto: prefer Enoki if configured, else use ZKLOGIN_PROVER_URL
# - enoki: always use Enoki
# - docker: always use ZKLOGIN_PROVER_URL
ZKLOGIN_PROVER_PROVIDER=auto

# Which Sui network your app is operating on.
# Used by the Enoki prover provider to request proofs for the correct network.
# Must be enabled for your Enoki API key.
# Allowed: testnet | devnet | mainnet
SUI_NETWORK=testnet

# Enoki (recommended if you want to avoid managing zkLogin.zkey yourself)
# NOTE: Fill these only if you are using Enoki.
# Versioned base URL (from https://docs.enoki.mystenlabs.com/http-api):
#   https://api.enoki.mystenlabs.com/v1
ENOKI_API_BASE_URL=https://api.enoki.mystenlabs.com/v1
ENOKI_API_KEY=

# zkLogin prover endpoint (Mysten hosted or your own)
# IMPORTANT:
# The default Mysten-hosted prover URL is NOT reachable from some environments (e.g. Vercel in certain regions)
# due to DNS/egress restrictions. If Google zkLogin fails with ENOTFOUND/502 from /api/zklogin/proof,
# you must set this to a prover URL that your runtime can reach (typically your own VPS domain).
#
# Example (self-hosted):
# ZKLOGIN_PROVER_URL=https://prover.your-domain.com/v1
ZKLOGIN_PROVER_URL=

# ─── Storage (Walrus-first) ───
# Storage provider selection: walrus | pinata
STORAGE_PROVIDER=walrus

# Walrus publisher endpoint (write API)
# Must be a full upload endpoint path, not host root.
# Example: https://publisher.walrus-testnet.dev/v1/store
WALRUS_PUBLISHER_URL=

# Walrus gateway/read base URL
# Must be the base used as <base>/<blobId>.
# Example: https://aggregator.walrus-testnet.dev/v1
WALRUS_GATEWAY_BASE_URL=

# Optional Walrus auth token/header bearer value
WALRUS_API_KEY=

# Pinata fallback (server-side only)
PINATA_JWT=

# Optional upload API hardening
# If true, /api/storage/upload requires x-storage-auth header matching STORAGE_AUTH_TOKEN
STORAGE_REQUIRE_AUTH=false
STORAGE_AUTH_TOKEN=

# Optional limits (defaults: 10MB, 20 req/min)
STORAGE_MAX_UPLOAD_MB=10
STORAGE_RATE_LIMIT_MAX=20
STORAGE_RATE_LIMIT_WINDOW_MS=60000

# Optional: auto-fallback to Pinata if Walrus is unreachable (DNS/5xx/timeouts)
STORAGE_WALRUS_FALLBACK_TO_PINATA=true
